#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

project_dir=""
for ((i=1; i<=$#; i++)); do
  arg="${!i}"
  if [[ "$arg" == "--dir" ]]; then
    j=$((i+1))
    if [[ $j -le $# ]]; then
      project_dir="${!j}"
    fi
    break
  fi
done

if [[ -n "$project_dir" ]]; then
  cache_dir="${project_dir}/.multipowers/temp/bin"
else
  cache_dir="${ROOT_DIR}/.cache/bin"
fi

mkdir -p "$cache_dir"
BIN_PATH="${cache_dir}/mp"

if [[ ! -x "$BIN_PATH" || "$ROOT_DIR/cmd/octo/main.go" -nt "$BIN_PATH" ]]; then
  if ! command -v go >/dev/null 2>&1; then
    echo "ERROR: go is required to bootstrap mp runtime. Install Go or prebuild bin/mp." >&2
    exit 127
  fi
  go build -o "$BIN_PATH" "${ROOT_DIR}/cmd/octo"
fi

exec "$BIN_PATH" "$@"
