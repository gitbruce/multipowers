#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_PATH="${ROOT_DIR}/.claude-plugin/bin/mp"

source_is_newer() {
  local bin="$1"
  shift
  find "$@" -type f -name '*.go' -newer "${bin}" -print -quit | grep -q .
}

needs_build=0
if [[ ! -x "${BIN_PATH}" ]]; then
  needs_build=1
elif [[ "${ROOT_DIR}/go.mod" -nt "${BIN_PATH}" || ( -f "${ROOT_DIR}/go.sum" && "${ROOT_DIR}/go.sum" -nt "${BIN_PATH}" ) ]]; then
  needs_build=1
elif source_is_newer "${BIN_PATH}" "${ROOT_DIR}/cmd/mp" "${ROOT_DIR}/internal" "${ROOT_DIR}/pkg"; then
  needs_build=1
fi

if [[ "${needs_build}" -eq 1 ]]; then
  (
    cd "${ROOT_DIR}"
    mkdir -p "${ROOT_DIR}/.claude-plugin/bin"
    go build -o "${BIN_PATH}" ./cmd/mp >/dev/null
  )
fi

exec "${BIN_PATH}" "$@"
