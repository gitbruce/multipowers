#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_PATH="${ROOT_DIR}/.claude-plugin/bin/mp"

if [[ ! -x "${BIN_PATH}" || "${ROOT_DIR}/cmd/octo/main.go" -nt "${BIN_PATH}" ]]; then
  (
    cd "${ROOT_DIR}"
    mkdir -p "${ROOT_DIR}/.claude-plugin/bin"
    go build -o "${BIN_PATH}" ./cmd/octo >/dev/null
  )
fi

exec "${BIN_PATH}" "$@"
